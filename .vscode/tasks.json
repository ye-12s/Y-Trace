{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure",
            "type": "shell",
            "command": "cmake --preset debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "build",
            "type": "shell",
            "command": "cmake --build --preset debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cmake --build --preset debug --target clean",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "download",
            "type": "shell",
            "command": "jf flash ${workspaceFolder}/build/cmake/Y-Trace.hex --chip AT32F403AVGT7",
            "dependsOn": "build",
            "problemMatcher": []
        }
    ]
}
